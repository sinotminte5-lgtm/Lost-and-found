<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>

<StackPane alignment="CENTER" prefHeight="600.0" prefWidth="800.0" style="-fx-background-color: #E6F0F8;" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.lostid.controllers.SignupController">
    <children>
        <VBox alignment="CENTER" maxWidth="450.0" spacing="15.0" style="-fx-background-color: white; -fx-background-radius: 15; -fx-padding: 40;">
            <children>
                <Label style="-fx-font-weight: bold; -fx-font-size: 22px;" text="CREATE ACCOUNT" />

                <TextField fx:id="fullNameField" promptText="Full Name" prefHeight="40.0" style="-fx-background-radius: 8;" />
                <TextField fx:id="departmentField" promptText="Department" prefHeight="40.0" style="-fx-background-radius: 8;" />
                <TextField fx:id="sectionField" promptText="Section / Batch" prefHeight="40.0" style="-fx-background-radius: 8;" />
                <TextField fx:id="otherField" promptText="Contact / Email" prefHeight="40.0" style="-fx-background-radius: 8;" />

                <PasswordField fx:id="passwordField" promptText="Create Password" prefHeight="40.0" style="-fx-background-radius: 8;" />

                <Button onAction="#handleSignup" prefHeight="45.0" prefWidth="Infinity" style="-fx-background-color: #4285F4; -fx-text-fill: white; -fx-font-weight: bold;" text="Sign Up" />
                <Button onAction="#handleBack" prefHeight="40.0" prefWidth="Infinity" style="-fx-background-color: #9E9E9E; -fx-text-fill: white;" text="Back to Login" />
            </children>
        </VBox>
    </children>
</StackPane>