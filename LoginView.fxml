<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Hyperlink?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.effect.DropShadow?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.text.Font?>

<StackPane alignment="CENTER" prefHeight="600.0" prefWidth="800.0" style="-fx-background-color: #E6F0F8;" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.lostid.controllers.LoginController">
    <children>
        <VBox alignment="CENTER" maxWidth="400.0" prefHeight="400.0" prefWidth="350.0" spacing="20.0" style="-fx-background-color: white; -fx-background-radius: 15; -fx-padding: 40;">
            <effect>
                <DropShadow blurType="GAUSSIAN" color="#00000033" height="30.0" radius="14.5" width="30.0" />
            </effect>
            <children>
                <Label alignment="CENTER" style="-fx-font-weight: bold;" text="LOST &amp; FOUND">
                    <font>
                        <Font size="22.0" />
                    </font>
                    <VBox.margin>
                        <Insets bottom="30.0" />
                    </VBox.margin>
                </Label>

                <TextField fx:id="usernameField" promptText="Username or email" prefHeight="45.0"
                           style="-fx-background-color: white; -fx-border-color: #DDDDDD; -fx-border-radius: 8; -fx-background-radius: 8; -fx-padding: 0 10; -fx-font-size: 14px;" />

                <PasswordField fx:id="passwordField" promptText="Password" prefHeight="45.0"
                               style="-fx-background-color: white; -fx-border-color: #DDDDDD; -fx-border-radius: 8; -fx-background-radius: 8; -fx-padding: 0 10; -fx-font-size: 14px;" />

                <Button onAction="#handleLogin" prefHeight="45.0" prefWidth="1.7976931348623157E308"
                        style="-fx-background-color: #4285F4; -fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 16px; -fx-background-radius: 8;" text="LOGIN" />

                <HBox alignment="CENTER" spacing="5.0">
                    <children>
                        <Label style="-fx-text-fill: #A0A0A0;" text="Don't have an account?" />
                        <Hyperlink onAction="#handleSignup" style="-fx-text-fill: #4285F4; -fx-font-weight: bold; -fx-padding: 0;" text="Sign up" />
                    </children>
                </HBox>
            </children>
        </VBox>
    </children>
</StackPane>