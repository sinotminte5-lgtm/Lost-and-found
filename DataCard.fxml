<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.effect.DropShadow?>

<VBox spacing="5.0" style="-fx-background-color: white; -fx-background-radius: 10; -fx-padding: 15; -fx-border-color: #E0E0E0; -fx-border-radius: 10;" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1">
    <effect>
        <DropShadow color="#0000001a" radius="5" />
    </effect>
    <children>
        <Label fx:id="titleLabel" style="-fx-font-weight: bold; -fx-font-size: 16px; -fx-text-fill: #4285F4;" text="Title" />
        <Label fx:id="detail1Label" style="-fx-text-fill: #555;" text="Detail 1" />
        <Label fx:id="detail2Label" style="-fx-text-fill: #777; -fx-font-size: 12px;" text="Detail 2" />
        <Label fx:id="detail3Label" style="-fx-text-fill: #777; -fx-font-size: 12px;" text="Detail 3" />
    </children>
</VBox>