<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.effect.DropShadow?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<StackPane alignment="CENTER" prefHeight="600.0" prefWidth="800.0" style="-fx-background-color: #F8F9FA;" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.lostid.controllers.FoundIDFormController">
    <children>
        <VBox alignment="TOP_CENTER" maxWidth="450.0" prefHeight="450.0" prefWidth="450.0" spacing="15.0" style="-fx-background-color: white; -fx-background-radius: 15; -fx-padding: 40;">
            <effect>
                <DropShadow blurType="GAUSSIAN" color="#00000022" height="30.0" radius="14.5" width="30.0" />
            </effect>
            <children>
                <Label alignment="CENTER" style="-fx-font-weight: bold; -fx-text-fill: #343A40;" text="Report a Found ID">
                    <font>
                        <Font size="22.0" />
                    </font>
                    <VBox.margin>
                        <Insets bottom="5.0" />
                    </VBox.margin>
                </Label>

                <Label alignment="CENTER" wrapText="true" style="-fx-font-size: 13px; -fx-text-fill: #6C757D;" text="Enter the ID number you found. Your name will be recorded as the finder." />

                <VBox spacing="5.0">
                    <children>
                        <Label text="Student ID Number" style="-fx-font-weight: bold; -fx-text-fill: #495057;" />
                        <TextField fx:id="studentIdField" promptText="Enter ID number from the card" prefHeight="45.0"
                                   style="-fx-background-color: white; -fx-border-color: #DEE2E6; -fx-border-radius: 8; -fx-background-radius: 8; -fx-padding: 0 10; -fx-font-size: 14px;" />
                    </children>
                </VBox>

                <VBox spacing="5.0">
                    <children>
                        <Label text="Location Found" style="-fx-font-weight: bold; -fx-text-fill: #495057;" />
                        <TextArea fx:id="descArea" promptText="Where did you find this ID? (e.g. Library, Block 2)" prefHeight="100.0" wrapText="true"
                                  style="-fx-background-color: white; -fx-border-color: #DEE2E6; -fx-border-radius: 8; -fx-background-radius: 8; -fx-padding: 10; -fx-font-size: 14px;" />
                    </children>
                </VBox>

                <Button onAction="#handleSubmit" prefHeight="45.0" prefWidth="1.7976931348623157E308"
                        style="-fx-background-color: #4285F4; -fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 15px; -fx-background-radius: 8; -fx-cursor: hand;" text="Submit Report" />

                <Button onAction="#handleBack" prefHeight="40.0" prefWidth="1.7976931348623157E308"
                        style="-fx-background-color: transparent; -fx-text-fill: #6C757D; -fx-font-weight: bold;" text="Cancel" />
            </children>
        </VBox>
    </children>
</StackPane>