<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.effect.DropShadow?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<StackPane prefHeight="720.0" prefWidth="1150.0" style="-fx-background-color: #F4F7F9;" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.lostid.controllers.AdminDashboardController">
    <children>
        <BorderPane>
            <left>
                <VBox prefWidth="230.0" spacing="10.0" style="-fx-background-color: white; -fx-border-color: #E0E4E8; -fx-border-width: 0 1 0 0;">
                    <padding><Insets bottom="20.0" left="15.0" right="15.0" top="30.0" /></padding>
                    <children>
                        <Label text="Admin Panel" textFill="#4285F4" style="-fx-font-weight: bold; -fx-font-size: 20px;">
                            <VBox.margin><Insets bottom="20.0" left="10.0"/></VBox.margin>
                        </Label>
                        <Button fx:id="btnDashboard" onAction="#showDashboard" alignment="BASELINE_LEFT" maxWidth="Infinity" prefHeight="45.0" text="📑  Dashboard" />
                        <Button fx:id="btnUsers" onAction="#showUsersList" alignment="BASELINE_LEFT" maxWidth="Infinity" prefHeight="45.0" text="👤  Users" />
                        <Button fx:id="btnLost" onAction="#showLostList" alignment="BASELINE_LEFT" maxWidth="Infinity" prefHeight="45.0" text="📰  Lost IDs" />
                        <Button fx:id="btnFound" onAction="#showFoundList" alignment="BASELINE_LEFT" maxWidth="Infinity" prefHeight="45.0" text="🔍  Found IDs" />
                        <Region VBox.vgrow="ALWAYS" />
                        <Button onAction="#handleLogout" maxWidth="Infinity" prefHeight="40.0" style="-fx-background-color: #FEEBEB; -fx-text-fill: #EF5350; -fx-font-weight: bold; -fx-background-radius: 8; -fx-border-color: #EF5350; -fx-border-radius: 8;" text="Logout" />
                    </children>
                </VBox>
            </left>

            <center>
                <VBox spacing="0">
                    <HBox alignment="CENTER_LEFT" prefHeight="70.0" style="-fx-background-color: white; -fx-padding: 0 40;">
                        <children>
                            <Label text="Campus ID Management System" style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #343A40;" />
                            <Region HBox.hgrow="ALWAYS" />
                            <Button onAction="#handleBack" prefHeight="35.0" style="-fx-background-color: #F1F3F4; -fx-text-fill: #5F6368; -fx-background-radius: 5;" text="Back to Home" />
                        </children>
                    </HBox>

                    <VBox spacing="25.0" VBox.vgrow="ALWAYS">
                        <padding><Insets bottom="30.0" left="40.0" right="40.0" top="30.0" /></padding>
                        <children>
                            <HBox spacing="20.0">
                                <children>
                                    <VBox fx:id="totalUsersCard" prefHeight="110.0" prefWidth="220.0" style="-fx-background-color: white; -fx-background-radius: 12; -fx-padding: 20; -fx-cursor: hand;">
                                        <effect><DropShadow blurType="GAUSSIAN" color="#00000008" height="10" radius="5" /></effect>
                                        <Label text="Total Users" textFill="#10B981" style="-fx-font-weight: bold;" />
                                        <Label fx:id="totalUsersLabel" text="0" style="-fx-font-size: 28px; -fx-font-weight: bold;" />
                                    </VBox>
                                    <VBox fx:id="totalLostCard" prefHeight="110.0" prefWidth="220.0" style="-fx-background-color: white; -fx-background-radius: 12; -fx-padding: 20; -fx-cursor: hand;">
                                        <effect><DropShadow blurType="GAUSSIAN" color="#00000008" height="10" radius="5" /></effect>
                                        <Label text="Lost Reports" textFill="#EF4444" style="-fx-font-weight: bold;" />
                                        <Label fx:id="lostIdLabel" text="0" style="-fx-font-size: 28px; -fx-font-weight: bold;" />
                                    </VBox>
                                    <VBox fx:id="totalFoundCard" prefHeight="110.0" prefWidth="220.0" style="-fx-background-color: white; -fx-background-radius: 12; -fx-padding: 20; -fx-cursor: hand;">
                                        <effect><DropShadow blurType="GAUSSIAN" color="#00000008" height="10" radius="5" /></effect>
                                        <Label text="Found Reports" textFill="#3B82F6" style="-fx-font-weight: bold;" />
                                        <Label fx:id="foundIdLabel" text="0" style="-fx-font-size: 28px; -fx-font-weight: bold;" />
                                    </VBox>
                                    <VBox fx:id="matchingIDsCard" prefHeight="110.0" prefWidth="220.0" style="-fx-background-color: white; -fx-background-radius: 12; -fx-padding: 20; -fx-cursor: hand;">
                                        <effect><DropShadow blurType="GAUSSIAN" color="#00000008" height="10" radius="5" /></effect>
                                        <Label text="Matches Found" textFill="#F59E0B" style="-fx-font-weight: bold;" />
                                        <Label fx:id="matchLabel" text="0" style="-fx-font-size: 28px; -fx-font-weight: bold;" />
                                    </VBox>
                                </children>
                            </HBox>

                            <VBox spacing="15" style="-fx-background-color: white; -fx-background-radius: 12; -fx-padding: 25;" VBox.vgrow="ALWAYS">
                                <effect><DropShadow blurType="GAUSSIAN" color="#00000008" height="20" radius="10" /></effect>
                                <children>
                                    <HBox alignment="CENTER_LEFT" spacing="15">
                                        <children>
                                            <Label fx:id="currentListTitle" text="User Management" style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #343A40;" />
                                            <Region HBox.hgrow="ALWAYS" />
                                            <TextField fx:id="searchField" prefWidth="300.0" promptText="🔍 Search by name, ID, or email..."
                                                       style="-fx-background-color: #F1F3F4; -fx-background-radius: 20; -fx-padding: 8 15; -fx-border-color: transparent;" />
                                        </children>
                                    </HBox>
                                    <Separator />
                                    <ScrollPane fitToWidth="true" style="-fx-background-color: transparent; -fx-background: transparent; -fx-border-color: transparent;">
                                        <VBox fx:id="listDataContainer" spacing="10" />
                                    </ScrollPane>
                                </children>
                            </VBox>
                        </children>
                    </VBox>
                </VBox>
            </center>
        </BorderPane>
    </children>
</StackPane>