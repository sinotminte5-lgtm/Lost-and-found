<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.effect.DropShadow?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<StackPane alignment="CENTER" prefHeight="600.0" prefWidth="800.0" style="-fx-background-color: #E6F0F8;" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.lostid.controllers.LostIDFormController">
    <children>
        <VBox alignment="TOP_CENTER" maxWidth="500.0" prefHeight="550.0" prefWidth="450.0" spacing="15.0" style="-fx-background-color: white; -fx-background-radius: 15; -fx-padding: 40;">
            <effect>
                <DropShadow blurType="GAUSSIAN" color="#00000033" height="30.0" radius="14.5" width="30.0" />
            </effect>
            <children>
                <Label alignment="CENTER" style="-fx-font-weight: bold;" text="Report Lost ID">
                    <font>
                        <Font size="22.0" />
                    </font>
                    <VBox.margin>
                        <Insets bottom="10.0" />
                    </VBox.margin>
                </Label>

                <TextField fx:id="fullNameField" editable="false" promptText="Student Name" prefHeight="40.0"
                           style="-fx-background-color: #F8F8F8; -fx-border-color: #DDDDDD; -fx-border-radius: 8; -fx-background-radius: 8; -fx-padding: 0 10; -fx-font-size: 14px; -fx-text-fill: #555;" />

                <TextField fx:id="studentIdField" promptText="Your Student ID Number" prefHeight="40.0"
                           style="-fx-background-color: white; -fx-border-color: #DDDDDD; -fx-border-radius: 8; -fx-background-radius: 8; -fx-padding: 0 10; -fx-font-size: 14px;" />

                <TextField fx:id="idDetailsField" promptText="Type of ID Lost (e.g., Student Card)" prefHeight="40.0"
                           style="-fx-background-color: white; -fx-border-color: #DDDDDD; -fx-border-radius: 8; -fx-background-radius: 8; -fx-padding: 0 10; -fx-font-size: 14px;" />

                <TextArea fx:id="locationDescArea" promptText="Describe where you lost it." prefHeight="150.0" wrapText="true"
                          style="-fx-background-color: white; -fx-border-color: #DDDDDD; -fx-border-radius: 8; -fx-background-radius: 8; -fx-padding: 10; -fx-font-size: 14px;" />

                <Button onAction="#handleSubmit" prefHeight="45.0" prefWidth="Infinity"
                        style="-fx-background-color: #4CAF50; -fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 16px; -fx-background-radius: 8;" text="Submit Lost Report" />

                <Button onAction="#handleBack" prefHeight="40.0" prefWidth="Infinity"
                        style="-fx-background-color: #9E9E9E; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 8;" text="Back to Dashboard" />
            </children>
        </VBox>
    </children>
</StackPane>